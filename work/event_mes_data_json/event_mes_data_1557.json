  "entries": [
    {
      "index": 0,
      "name": "0",
      "message": "いらっしゃいませ！[RAW:2823]気になるあの人との相性、[RAW:2823]とっても気になりませんか？[RAW:2B23]今ならたったの１００Ｇで、[RAW:2823]占ってさしあげます！[RAW:2823]いかがでしょうか？[RAW:0E27]",
      "original": "いらっしゃいませ！[RAW:2823]気になるあの人との相性、[RAW:2823]とっても気になりませんか？[RAW:2B23]今ならたったの１００Ｇで、[RAW:2823]占ってさしあげます！[RAW:2823]いかがでしょうか？[RAW:0E27]",
      "translation": "어서　오세요！[RAW:2823]신경　쓰이는　그분과[RAW:2823]궁합、궁금하지　않나요？[RAW:2B23]지금은　단　１００Ｇ로、[RAW:2823]점쳐　드립니다！[RAW:2823]어떠신가요？[RAW:0E27]",
      "controls": [
        "[RAW:2823]",
        "[RAW:2823]",
        "[RAW:2B23]",
        "[RAW:2823]",
        "[RAW:2823]",
        "[RAW:0E27]"
      ]
    },
    {
      "index": 1,
      "name": "1",
      "message": "[RAW:411F-A41F-481F-3323]　占ってください！[RAW:2823]　けっこうです[RAW:2823]　説明を聞く[RAW:0E27]",
      "original": "[RAW:411F-A41F-481F-3323]　占ってください！[RAW:2823]　けっこうです[RAW:2823]　説明を聞く[RAW:0E27]",
      "translation": "[RAW:411F-A41F-481F-3323]　점쳐　주세요！[RAW:2823]　괜찮습니다[RAW:2823]　설명을　듣기[RAW:0E27]",
      "controls": [
        "[RAW:411F-A41F-481F-3323]",
        "[RAW:2823]",
        "[RAW:2823]",
        "[RAW:0E27]"
      ]
    },
    {
      "index": 2,
      "name": "2",
      "message": "…占いはおきらいですか？[RAW:2823]でも、わたしめげません。[RAW:2823]いつでもお待ちしております！[RAW:0E27]",
      "original": "…占いはおきらいですか？[RAW:2823]でも、わたしめげません。[RAW:2823]いつでもお待ちしております！[RAW:0E27]",
      "translation": "…점은　싫으신가요？[RAW:2823]그래도、전　안　꺾여요。[RAW:2823]언제든　기다릴게요！[RAW:0E27]",
      "controls": [
        "[RAW:2823]",
        "[RAW:2823]",
        "[RAW:0E27]"
      ]
    },
    {
      "index": 3,
      "name": "3",
      "message": "あれ、お金がたりないです。[RAW:2823]ざんねんです…。[RAW:0E27]",
      "original": "あれ、お金がたりないです。[RAW:2823]ざんねんです…。[RAW:0E27]",
      "translation": "어라、금이　부족해요。[RAW:2823]아쉽네요…。[RAW:0E27]",
      "controls": [
        "[RAW:2823]",
        "[RAW:0E27]"
      ]
    },
