      ]
    },
    {
      "index": 3,
      "name": "3",
      "message": "[RAW:411F-A71F-481F-3621]あとはお金ですね。[RAW:2823-0010]Ｇ[RAW:2823]確かにいただきました。[RAW:0E27]",
      "original": "[RAW:411F-A71F-481F-3621]あとはお金ですね。[RAW:2823-0010]Ｇ[RAW:2823]確かにいただきました。[RAW:0E27]",
      "translation": "[RAW:411F-A71F-481F-3621]이젠 돈이네요。[RAW:2823-0010]Ｇ[RAW:2823]확실히 받았습니다。[RAW:0E27]",
      "controls": [
        "[RAW:411F-A71F-481F-3621]",
        "[RAW:2823-0010]",
        "[RAW:2823]",
        "[RAW:0E27]"
      ]
    },
    {
      "index": 4,
      "name": "4",
      "message": "[RAW:411F-A71F-481F-3621]あっ、話しは聞いてます。[RAW:2823]ありがとうございます。[RAW:2823]待っていたんですよ。[RAW:0E27]",
      "original": "[RAW:411F-A71F-481F-3621]あっ、話しは聞いてます。[RAW:2823]ありがとうございます。[RAW:2823]待っていたんですよ。[RAW:0E27]",
      "translation": "[RAW:411F-A71F-481F-3621]아、얘긴 들었어요。[RAW:2823]고맙습니다。[RAW:2823]기다리고 있었어요。[RAW:0E27]",
      "controls": [
        "[RAW:411F-A71F-481F-3621]",
        "[RAW:2823]",
        "[RAW:2823]",
        "[RAW:0E27]"
      ]
    },
    {
      "index": 5,
      "name": "5",
      "message": "[RAW:411F-A71F-491F-3621]さすがですね。[RAW:2823]ていねいなお仕事です。[RAW:2823]確かに受け取りました！[RAW:0E27]",
      "original": "[RAW:411F-A71F-491F-3621]さすがですね。[RAW:2823]ていねいなお仕事です。[RAW:2823]確かに受け取りました！[RAW:0E27]",
      "translation": "[RAW:411F-A71F-491F-3621]역시 대단하네요。[RAW:2823]참 꼼꼼하시네요。[RAW:2823]잘 받았습니다！[RAW:0E27]",
      "controls": [
        "[RAW:411F-A71F-491F-3621]",
        "[RAW:2823]",
        "[RAW:2823]",
        "[RAW:0E27]"
      ]
    },
    {
