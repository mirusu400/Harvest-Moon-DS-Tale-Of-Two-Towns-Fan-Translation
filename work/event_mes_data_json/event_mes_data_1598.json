    {
      "index": 3,
      "name": "3",
      "message": "[RAW:411F-AA1F-481F-3621]あとはお金だね。[RAW:2823-0010]Ｇ[RAW:2823]確かに受け取ったよ。[RAW:0E27]",
      "original": "[RAW:411F-AA1F-481F-3621]あとはお金だね。[RAW:2823-0010]Ｇ[RAW:2823]確かに受け取ったよ。[RAW:0E27]",
      "translation": "[RAW:411F-AA1F-481F-3621]이젠　돈이군。[RAW:2823-0010]Ｇ[RAW:2823]확실히　받았어。[RAW:0E27]",
      "controls": [
        "[RAW:411F-AA1F-481F-3621]",
        "[RAW:2823-0010]",
        "[RAW:2823]",
        "[RAW:0E27]"
      ]
    },
    {
      "index": 4,
      "name": "4",
      "message": "[RAW:411F-AA1F-481F-3621]話しは聞いてるよ。[RAW:2823]ありがとう。待ってたんだ。[RAW:0E27]",
      "original": "[RAW:411F-AA1F-481F-3621]話しは聞いてるよ。[RAW:2823]ありがとう。待ってたんだ。[RAW:0E27]",
      "translation": "[RAW:411F-AA1F-481F-3621]얘긴　들었어。[RAW:2823]고마워。기다렸어。[RAW:0E27]",
      "controls": [
